    {
      "id": "8iiSYNMLfdPigEQcv-Xng",
      "type": "text",
      "x": -605.4028443017405,
      "y": -303.6888781738273,
      "width": 1836.8997802734375,
      "height": 2175.257931179472,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0o",
      "roundness": null,
      "seed": 181025352,
      "version": 783,
      "versionNonce": 643181112,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772512310898,
      "link": null,
      "locked": false,
      "text": "Functional Requirments ->\n-> creators to create events and questions\n->Users opt for Yes/No for each questions\n->Dynamic for each current question based on current scenario\n\nNon-Functional Requirment:\nLow Latency\nScalable to large users\n\nCore Entities->\nEvent\nCategory(enum)\nOption/Question\n\nAPIs\n            POST /categories      \nPOST /categories/events\nGET /categories/events{id}\nGET /categories/events/questions{id} \nGET /bets/\n\n\n\nEvent \nService\n\n\n\n",
      "fontSize": 60.00711534288199,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional Requirments ->\n-> creators to create events and questions\n->Users opt for Yes/No for each questions\n->Dynamic for each current question based on current scenario\n\nNon-Functional Requirment:\nLow Latency\nScalable to large users\n\nCore Entities->\nEvent\nCategory(enum)\nOption/Question\n\nAPIs\n            POST /categories      \nPOST /categories/events\nGET /categories/events{id}\nGET /categories/events/questions{id} \nGET /bets/\n\n\n\nEvent \nService\n\n\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
